---
import { site } from '@/data/site';

const rolesList = site.roles;
const [firstName, ...rest] = site.name.split(' ');
const lastName = rest.join(' ');
const marqueeItems = [...site.roles, 'Baltimore, MD', 'UMBC'];
---

<section class="hero" id="top">
  <canvas class="hero__canvas" data-wave-canvas aria-hidden="true"></canvas>

  <div class="hero__content wrap">
    {site.available && (
      <p class="hero__status">
        <span class="hero__status-dot" aria-hidden="true"></span>
        Available for new work
      </p>
    )}

    <h1 class="hero__title">
      <span class="hero__title-line">{firstName}</span>
      <span class="hero__title-line hero__title-line--last">{lastName}</span>
    </h1>

    <p class="hero__role">
      <span class="hero__role-prefix" aria-hidden="true">field:</span>
      <span class="hero__role-text" data-roles={JSON.stringify(rolesList)}>{rolesList[0]}</span>
    </p>

    <p class="hero__tagline">{site.tagline}</p>

    <div class="hero__actions">
      <a class="btn btn--primary" href="#work" data-cursor-hover data-magnetic>View work</a>
      <a class="btn btn--ghost" href="#contact" data-cursor-hover data-magnetic>Get in touch</a>
    </div>
  </div>

  <a class="hero__scroll-cue" href="#work" aria-label="Scroll to work section" data-cursor-hover>
    <span></span>
  </a>

  <div class="hero__marquee marquee" aria-hidden="true">
    <div class="marquee__track" style="--marquee-speed: 34s;">
      <span class="marquee__group">
        {marqueeItems.map((item) => (
          <>
            <span class="hero__marquee-item">{item}</span>
            <span class="hero__marquee-leaf"></span>
          </>
        ))}
      </span>
      <span class="marquee__group">
        {marqueeItems.map((item) => (
          <>
            <span class="hero__marquee-item">{item}</span>
            <span class="hero__marquee-leaf"></span>
          </>
        ))}
      </span>
    </div>
  </div>
</section>

<script>
  import { initWaveField } from '@/scripts/wave';
  import { scrambleTo } from '@/scripts/scramble';
  import { initMagnetic } from '@/scripts/cursor';

  const canvas = document.querySelector<HTMLCanvasElement>('[data-wave-canvas]');
  if (canvas) {
    initWaveField(canvas);
  }

  initMagnetic('.hero [data-magnetic]', 70, 0.3);

  // Role text rotation, scrambling into place.
  const roleElement = document.querySelector<HTMLElement>('[data-roles]');
  if (roleElement) {
    const roles: string[] = JSON.parse(roleElement.dataset.roles || '[]');

    if (roles.length > 1) {
      let currentIndex = 0;
      setInterval(() => {
        currentIndex = (currentIndex + 1) % roles.length;
        scrambleTo(roleElement, roles[currentIndex], 500);
      }, 3500);
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% 0%, var(--paper-raised) 0%, var(--paper) 65%);
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: 7rem 9rem;
    pointer-events: none;
  }

  .hero__content > * {
    pointer-events: auto;
  }

  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
    padding: 0.45em 0.95em;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--paper-raised) 75%, transparent);
  }

  .hero__status-dot {
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--teal);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--coral) 45%, transparent);
    animation: hero-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-pulse {
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--coral) 20%, transparent);
    }
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    font-size: clamp(3.4rem, 13vw, 9.5rem);
    font-weight: 700;
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .hero__title-line--last {
    color: transparent;
    -webkit-text-stroke: 2px var(--ink);
    margin-left: 0.35em;
  }

  .hero__role {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--teal);
    display: flex;
    align-items: baseline;
    gap: 0.6em;
    white-space: pre;
  }

  .hero__role-prefix {
    color: var(--slate);
    font-size: 0.85em;
  }

  .hero__tagline {
    margin-top: 1.25rem;
    max-width: 42ch;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: var(--fg-muted);
  }

  .hero__actions {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero__scroll-cue {
    position: absolute;
    bottom: 5.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1.5rem;
    height: 2.5rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    display: flex;
    justify-content: center;
    padding-top: 0.4rem;
    z-index: 1;
  }

  .hero__scroll-cue span {
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: var(--teal);
    animation: hero-scroll-cue 1.8s ease-in-out infinite;
  }

  @keyframes hero-scroll-cue {
    0% {
      opacity: 1;
      transform: translateY(0);
    }
    70% {
      opacity: 0;
      transform: translateY(0.8rem);
    }
    100% {
      opacity: 0;
      transform: translateY(0.8rem);
    }
  }

  .hero__marquee {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--paper-raised) 70%, transparent);
    backdrop-filter: blur(4px);
    padding-block: 0.8rem;
  }

  .hero__marquee-item {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--slate);
    text-transform: uppercase;
  }

  .hero__marquee-leaf {
    width: 0.7em;
    height: 0.7em;
    border-radius: 0 60% 0 60%;
    background: var(--teal);
    transform: rotate(-8deg);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-cue span,
    .hero__status-dot {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .hero__title-line--last {
      margin-left: 0.15em;
    }

    .hero__scroll-cue {
      display: none;
    }
  }
</style>
