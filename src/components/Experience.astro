---
import { experience } from '@/data/site';
---

<div class="experience section" id="experience">
  <div class="wrap experience__inner" data-reveal>
    <div class="experience__head">
      <span class="eyebrow">Experience</span>
      <h2 class="section-title section-title--with-eyebrow">Where I've worked</h2>
    </div>

    <ol class="experience__timeline" data-reveal style="--reveal-delay: 0.12s;">
      {experience.map((item) => (
        <li class="experience__item">
          <svg class="experience__connector" viewBox="0 0 2 60" preserveAspectRatio="none" aria-hidden="true">
            <line data-drawline x1="1" y1="0" x2="1" y2="60" />
          </svg>

          <div class="experience__info">
            <span class="experience__title">{item.title}</span>
            <div class="experience__subhead">
              <span class="experience__org">{item.organization}</span>
              <span class="experience__separator">•</span>
              <span class="experience__date">{item.date}</span>
            </div>
          </div>

          <ul class="experience__bullets">
            {item.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </div>
</div>

<script>
  import { initScrollReveal } from '@/scripts/reveal';
  import { initDrawLines } from '@/scripts/drawline';

  initScrollReveal();
  initDrawLines('[data-drawline]');
</script>

<style>
  .experience__inner {
    display: flex;
    flex-direction: column;
  }

  .experience__timeline {
    margin-top: 3rem;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 2.5rem;
  }

  .experience__item {
    position: relative;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: start;
  }

  .experience__connector {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    overflow: visible;
  }

  .experience__connector line {
    stroke: var(--slate);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .experience__info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.35rem;
  }

  .experience__title {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--fg-primary);
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .experience__subhead {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .experience__org {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--teal);
  }

  .experience__separator {
    color: var(--line-strong);
    font-size: 0.8rem;
    user-select: none;
  }

  .experience__date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .experience__bullets {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    width: 100%;
    text-align: left;
  }

  .experience__bullets li {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .experience__bullets li::before {
    content: '';
    width: 0.4rem;
    height: 1px;
    background: var(--slate);
    flex-shrink: 0;
    margin-top: 0.75rem;
  }

  @media (max-width: 900px) {
    .experience__timeline {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
