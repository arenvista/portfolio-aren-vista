---
import { site, nav, socials } from '@/data/site';

// Inline currentColor icons — the old header imported white PNG/SVG assets
// that (a) don't exist in this repo snapshot and (b) were designed for a
// dark theme. These recolor with the palette for free.
const icons: Record<string, string> = {
  GitHub:
    'M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.11-.74.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z',
  GitLab:
    'M22.65 9.53l-.03-.08-2.9-7.57a.76.76 0 0 0-.3-.36.78.78 0 0 0-.88.05.78.78 0 0 0-.26.39l-1.96 5.99H7.68L5.72 1.96a.76.76 0 0 0-.26-.39.78.78 0 0 0-.88-.05.76.76 0 0 0-.3.36L1.38 9.45l-.03.08a5.38 5.38 0 0 0 1.79 6.22l.01.01.03.02 4.42 3.31 2.19 1.65 1.33 1.01a.9.9 0 0 0 1.08 0l1.33-1.01 2.19-1.65 4.45-3.33.01-.01a5.38 5.38 0 0 0 1.78-6.22Z',
  LinkedIn:
    'M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z',
};
---

<header class="site-header">
  <div class="site-header__container wrap">
    <a href="#top" class="site-header__mark" aria-label={`${site.name} — home`} data-cursor-hover>
      <span class="site-header__leaf" aria-hidden="true"></span>
      <span class="site-header__name">{site.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary" data-nav-underline>
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} data-cursor-hover>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__end">
      <button type="button" class="cp-trigger" data-cp-trigger data-cursor-hover aria-label="Open quick navigation">
        <span class="cp-trigger__label">Quick Nav</span>
        <span class="cp-trigger__kbd">⌘K</span>
      </button>

      <div class="social-icon">
        {socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} data-cursor-hover>
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor">
              <path d={icons[social.label]} />
            </svg>
          </a>
        ))}
      </div>

      <button
        type="button"
        class="site-header__burger"
        data-menu-toggle
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
        data-cursor-hover
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<!-- Kept outside <header>: its backdrop-filter would otherwise become the
     containing block for this fixed overlay, collapsing it to header height. -->
<div class="mobile-menu" id="mobile-menu" data-mobile-menu>
    <nav aria-label="Mobile">
      <ul class="mobile-menu__list">
        {nav.map((item, i) => (
          <li style={`--i:${i}`}>
            <a href={item.href} data-menu-link>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-menu__socials">
      {socials.map((social) => (
        <a href={social.href} target="_blank" rel="noopener noreferrer">{social.label} ↗</a>
      ))}
    </div>
</div>

<script>
  import { initNavUnderline } from '@/scripts/navUnderline';
  initNavUnderline('[data-nav-underline] ul');

  // Mobile menu — the old header simply hid the nav below 640px with no
  // replacement, leaving phones with no navigation at all.
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('is-open', open);
      toggle.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => setOpen(!menu.classList.contains('is-open')));
    menu.querySelectorAll('[data-menu-link]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) setOpen(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    border-bottom: 1px solid var(--line);
  }

  .site-header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: var(--header-h);
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--fg-primary);
    letter-spacing: -0.01em;
  }

  .site-header__leaf {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 0 60% 0 60%;
    background: linear-gradient(135deg, var(--coral), var(--teal));
    transform: rotate(-8deg);
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-header__mark:hover .site-header__leaf {
    transform: rotate(82deg);
  }

  .site-header__nav ul {
    position: relative;
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.25rem);
  }

  .site-header__nav a {
    position: relative;
    z-index: 1;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-muted);
    transition: color 0.2s ease;
  }

  .site-header__nav a:hover {
    color: var(--teal);
  }

  :global(.nav-underline) {
    position: absolute;
    bottom: -0.4rem;
    left: 0;
    height: 2px;
    width: 0;
    opacity: 0;
    background: var(--teal);
    border-radius: 999px;
    pointer-events: none;
  }

  .site-header__end {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Command palette trigger — sits in the header rather than floating. */
  .cp-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 2.4rem;
    padding-inline: 0.75rem;
    background: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease;
  }

  .cp-trigger:hover {
    border-color: var(--teal);
    color: var(--teal);
  }

  .cp-trigger__kbd {
    padding: 0.15em 0.45em;
    border: 1px solid var(--line-strong);
    border-radius: 5px;
    font-size: 0.65rem;
    color: var(--fg-faint);
  }

  .cp-trigger:hover .cp-trigger__kbd {
    border-color: currentColor;
  }

  .social-icon {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .social-icon a {
    position: relative;
    width: 2.4rem;
    height: 2.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--line);
    color: var(--fg-muted);
    overflow: hidden;
    transition: color 0.25s ease, border-color 0.25s ease;
  }

  .social-icon a::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    border-radius: 50%;
    transform: scale(0);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .social-icon a:hover {
    color: var(--coral);
    border-color: var(--ink);
  }

  .social-icon a:hover::before {
    transform: scale(1);
  }

  .social-icon svg {
    position: relative;
    z-index: 1;
  }

  /* Burger */
  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 2.4rem;
    height: 2.4rem;
    align-items: center;
  }

  .site-header__burger span {
    display: block;
    width: 1.35rem;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .site-header__burger.is-open span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .site-header__burger.is-open span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Mobile overlay menu */
  .mobile-menu {
    position: fixed;
    inset: var(--header-h) 0 0 0;
    z-index: 49;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.5rem, 6vw, 3rem);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu__list li {
    border-bottom: 1px solid var(--line);
    transform: translateY(12px);
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--i) * 0.05s);
  }

  .mobile-menu.is-open .mobile-menu__list li {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu__list a {
    display: block;
    padding-block: 1rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 9vw, 3rem);
    font-weight: 600;
    text-decoration: none;
    color: var(--ink);
  }

  .mobile-menu__list a:active {
    color: var(--teal);
  }

  .mobile-menu__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .mobile-menu__socials a {
    text-decoration: none;
    color: var(--fg-faint);
  }

  @media (max-width: 720px) {
    .site-header__nav,
    .social-icon,
    .cp-trigger {
      display: none;
    }

    .site-header__burger {
      display: flex;
    }
  }

  @media (min-width: 721px) {
    .mobile-menu {
      display: none;
    }
  }
</style>
