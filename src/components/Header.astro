---
import { site, nav } from '@/data/site';
---

<header class="site-header">
  <div class="site-header__container wrap">
    <a href="#top" class="site-header__mark" aria-label={`${site.name} — home`}>
      <span class="site-header__dot" aria-hidden="true"></span>
      <span class="site-header__name">{site.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a class="btn btn--ghost site-header__cta" href="#contact">Say hello</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg-page) 78%, transparent);
    border-bottom: 1px solid var(--border-subtle);
  }

  .site-header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.25rem;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--fg-primary);
    letter-spacing: -0.01em;
  }

  .site-header__dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-mauve), var(--accent-blue));
    flex-shrink: 0;
  }

  .site-header__nav ul {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.25rem);
  }

  .site-header__nav a {
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-muted);
    transition: color 0.2s ease;
  }

  .site-header__nav a:hover {
    color: var(--accent-teal);
  }

  .site-header__cta {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .site-header__nav {
      display: none;
    }
  }
</style>
