---
import { projects } from '@/data/projects';

const featured = projects.filter((p) => p.showcase);
const count = featured.length;
const allTags = Array.from(new Set(projects.flatMap((p) => p.tags))).sort();
const pad = (n: number) => String(n).padStart(2, '0');
---

<section class="show" id="work">
  <div class="show__intro wrap">
    <div class="section-head">
      <div>
        <span class="eyebrow eyebrow--on-ink">Selected work</span>
        <h2 class="section-title section-title--with-eyebrow show__title">Field specimens</h2>
      </div>
      <p class="section-note show__note">Keep scrolling — every frame is running live. Click one to open it.</p>
    </div>
  </div>

  <div class="show__scroller" data-showcase style={`--count: ${count};`}>
    <div class="show__sticky">
      {featured.map((project, i) => {
        const external = project.href.startsWith('http');
        return (
          <a
            class="show-frame"
            data-frame
            href={project.href}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            data-cursor-label="View"
            aria-label={`${project.title} — open project`}
          >
            {/* The plate is what the wipe reveals: media, scrim, and the
               name/summary. The meta header (fig + tags) lives outside it so
               the top-down wipe can't clip it — it cross-fades instead. */}
            <div class="show-frame__plate" data-plate>
              <div class="show-frame__media-wrap">
                {project.video ? (
                  <video
                    data-media
                    class="show-frame__media"
                    src={project.video}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  ></video>
                ) : (
                  <canvas data-media data-preview={project.preview ?? 'boot'} class="show-frame__media"></canvas>
                )}
              </div>
              <div class="show-frame__scrim" aria-hidden="true"></div>

              <div class="show-frame__foot">
                <h3 class="show-frame__name">{project.title}</h3>
                <p class="show-frame__summary">{project.summary}</p>
                <span class="show-frame__visit">Visit ↗</span>
              </div>
            </div>

            <header class="show-frame__meta" data-meta>
              <span class="show-frame__fig">fig. {pad(i + 1)} — {project.year}</span>
              <ul class="show-frame__tags" aria-label="Technologies used">
                {project.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </header>
          </a>
        );
      })}

      <aside class="show-rail" aria-hidden="true">
        <div class="show-rail__dots">
          {featured.map((project) => (
            <button type="button" class="show-rail__dot" data-rail-dot title={project.title}></button>
          ))}
        </div>
        <div class="show-rail__counter">
          <span class="show-rail__clip">
            <span class="show-rail__col" data-counter-col>
              {featured.map((_, i) => (
                <span class="show-rail__num">{pad(i + 1)}</span>
              ))}
            </span>
          </span>
          <span class="show-rail__total">/ {pad(count)}</span>
        </div>
      </aside>
    </div>
  </div>

  <div class="archive wrap" id="archive">
    <div class="section-head archive__head">
      <div>
        <span class="eyebrow eyebrow--on-ink">Archive</span>
        <h2 class="section-title section-title--with-eyebrow show__title">Everything, indexed</h2>
      </div>
      <p class="section-note show__note">The full collection, filterable by stack.</p>
    </div>

    <div class="archive__filters" data-project-filters role="group" aria-label="Filter projects by technology">
      <button type="button" class="filter-btn filter-btn--active" data-filter="all" data-cursor-hover>All</button>
      {allTags.map((tag) => (
        <button type="button" class="filter-btn" data-filter={tag.toLowerCase()} data-cursor-hover>{tag}</button>
      ))}
    </div>

    <ol class="archive__list" data-project-grid>
      {projects.map((project, i) => {
        const external = project.href.startsWith('http');
        return (
          <li class="archive-row" data-tags={project.tags.map((t) => t.toLowerCase()).join(' ')}>
            <a
              class="archive-row__link"
              href={project.href}
              target={external ? '_blank' : undefined}
              rel={external ? 'noopener noreferrer' : undefined}
              data-cursor-hover
            >
              <span class="archive-row__index">{pad(i + 1)}</span>
              <span class="archive-row__name">
                {project.title}
                {project.featured && <span class="archive-row__star" title="Featured">✳</span>}
              </span>
              <span class="archive-row__summary">{project.summary}</span>
              <span class="archive-row__year">{project.year}</span>
              <span class="archive-row__arrow" aria-hidden="true">↗</span>
            </a>
            {project.repo && project.repo !== project.href && (
              <a
                class="archive-row__source"
                href={project.repo}
                target="_blank"
                rel="noopener noreferrer"
                data-cursor-hover
              >
                Source
              </a>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</section>

<script>
  import { initShowcase } from '@/scripts/showcase';
  import { initFilterFlip } from '@/scripts/filterFlip';

  initShowcase('[data-showcase]');
  initFilterFlip('[data-project-grid]', '[data-project-filters]', 'archive-row--hidden');
</script>

<style>
  .show {
    background: var(--deep-sea);
    color: var(--paper);
  }

  .show__intro {
    padding-block: clamp(4rem, 8vw, 6rem) clamp(1.5rem, 3vw, 2.5rem);
  }

  .show__title {
    color: var(--paper);
  }

  .show__note {
    color: var(--steel);
  }

  /* ---- Pinned scroller ------------------------------------------------ */
  .show__scroller {
    position: relative;
    height: calc(var(--count) * 100svh + 100svh);
  }

  .show__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
  }

  .show-frame {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
    color: var(--paper);
    visibility: hidden;
    /* Own stacking context so a frame's z-indexed children (meta above the
       dim, foot inside the plate) never leak across frames. */
    isolation: isolate;
  }

  /* The wiped plate: media, scrim, and the name/summary. The wipe clip and
     the recede transform live here, so the meta header — a sibling — is never
     clipped. */
  .show-frame__plate {
    position: absolute;
    inset: 0;
    will-change: clip-path, transform;
    transform-origin: center;
  }

  /* Recede dim — covers the outgoing plate as the next frame slides over. */
  .show-frame::before {
    content: '';
    position: absolute;
    inset: clamp(0.75rem, 2vw, 1.5rem);
    border-radius: var(--radius-lg);
    background: var(--ink);
    opacity: var(--dim, 0);
    z-index: 3;
    pointer-events: none;
  }

  /* Feathered leading edge that rides the wipe line on the incoming frame. */
  .show-frame::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: var(--wipe, 0%);
    height: clamp(70px, 14vh, 150px);
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--apricot) 80%, transparent) 0 2px,
      rgba(13, 23, 27, 0.35) 2px,
      transparent 100%
    );
    opacity: var(--edge, 0);
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .show-frame:first-child {
    visibility: visible;
  }

  .show-frame__media-wrap {
    position: absolute;
    inset: clamp(0.75rem, 2vw, 1.5rem);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--line-on-ink);
    background: #1a2b33;
  }

  .show-frame__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.06);
    will-change: transform;
  }

  .show-frame__scrim {
    position: absolute;
    inset: clamp(0.75rem, 2vw, 1.5rem);
    border-radius: var(--radius-lg);
    pointer-events: none;
    background:
      linear-gradient(to bottom, rgba(33, 53, 61, 0.55) 0%, transparent 22%),
      linear-gradient(to top, rgba(33, 53, 61, 0.78) 0%, transparent 45%);
  }

  .show-frame__meta {
    position: absolute;
    /* Above the recede dim (::before, z-index 3) so the meta fades on its own
       opacity, driven by the scroller, rather than being dimmed with the
       plate. */
    z-index: 4;
    opacity: 1;
    will-change: opacity;
    top: clamp(5.75rem, 4vw, 3rem);
    left: clamp(1.75rem, 4vw, 3rem);
    right: clamp(1.75rem, 4vw, 3rem);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .show-frame__fig {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--apricot);
  }

  .show-frame__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .show-frame__tags li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.25em 0.7em;
    border-radius: 999px;
    border: 1px solid var(--line-on-ink-strong);
    color: var(--apricot);
    background: rgba(33, 53, 61, 0.4);
    backdrop-filter: blur(4px);
  }

  .show-frame__foot {
    position: absolute;
    z-index: 2;
    left: clamp(1.75rem, 4vw, 3rem);
    right: clamp(1.75rem, 4vw, 3rem);
    bottom: clamp(1.75rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: 'name visit' 'summary visit';
    align-items: end;
    gap: 0.5rem 1.5rem;
  }

  .show-frame__name {
    grid-area: name;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--paper);
  }

  .show-frame__summary {
    grid-area: summary;
    max-width: 52ch;
    color: var(--apricot);
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
  }

  .show-frame__visit {
    grid-area: visit;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.7em 1.3em;
    border-radius: 999px;
    background: var(--coral);
    color: var(--ink);
    white-space: nowrap;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .show-frame:hover .show-frame__visit {
    background: var(--teal);
    transform: translateY(-2px);
  }

  .show-frame:focus-visible {
    outline: none;
  }

  .show-frame:focus-visible .show-frame__media-wrap {
    outline: 3px solid var(--coral);
    outline-offset: -3px;
  }

  /* ---- Rail ------------------------------------------------------------ */
  .show-rail {
    position: absolute;
    right: clamp(1.5rem, 3.5vw, 3rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .show-rail__dots {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .show-rail__dot {
    width: 0.55rem;
    height: 0.55rem;
    padding: 0;
    border-radius: 50%;
    background: rgba(250, 243, 230, 0.35);
    transition: background-color 0.25s ease, transform 0.25s ease;
  }

  .show-rail__dot:hover {
    background: var(--apricot);
  }

  .show-rail__dot.is-active {
    background: var(--coral);
    transform: scale(1.5);
  }

  .show-rail__counter {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--apricot);
  }

  .show-rail__clip {
    display: block;
    height: 1.3em;
    overflow: hidden;
  }

  .show-rail__col {
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .show-rail__num {
    display: block;
    height: 1.3em;
    line-height: 1.3;
    color: var(--apricot);
    font-weight: 600;
  }

  .show-rail__total {
    color: var(--steel);
  }

  @media (prefers-reduced-motion: reduce) {
    .show-rail__col {
      transition: none;
    }
  }

  @media (max-width: 720px) {
    .show-rail {
      right: 1rem;
      gap: 1rem;
    }

    .show-frame__summary {
      display: none;
    }

    .show-frame__foot {
      grid-template-columns: 1fr;
      grid-template-areas: 'name' 'visit';
      justify-items: start;
    }
  }

  /* ---- Archive --------------------------------------------------------- */
  .archive {
    padding-block: clamp(4rem, 8vw, 6rem);
  }

  .archive__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  /* On-ink overrides for the shared filter buttons */
  .archive .filter-btn {
    border-color: var(--line-on-ink);
    color: var(--steel);
  }

  .archive .filter-btn:hover {
    border-color: var(--apricot);
    color: var(--apricot);
  }

  .archive .filter-btn--active,
  .archive .filter-btn--active:hover {
    border-color: var(--coral);
    background: var(--coral);
    color: var(--ink);
  }

  .archive__list {
    counter-reset: none;
    border-top: 1px solid var(--line-on-ink);
  }

  .archive-row {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--line-on-ink);
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .archive-row--hidden {
    display: none;
  }

  .archive-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250, 243, 230, 0.06);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .archive-row:hover::before {
    transform: scaleY(1);
  }

  .archive-row__link {
    flex: 1;
    display: grid;
    grid-template-columns: 3rem minmax(10rem, 0.7fr) 1.6fr auto auto;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.35rem 0.5rem;
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .archive-row__index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--steel);
  }

  .archive-row__name {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: 600;
    color: var(--paper);
    transition: color 0.2s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .archive-row:hover .archive-row__name {
    color: var(--apricot);
    transform: translateX(0.4rem);
  }

  .archive-row__star {
    color: var(--coral);
    margin-left: 0.4em;
    font-size: 0.8em;
  }

  .archive-row__summary {
    color: var(--steel);
    font-size: 0.9rem;
  }

  .archive-row__year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--steel);
  }

  .archive-row__arrow {
    color: var(--apricot);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .archive-row:hover .archive-row__arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  .archive-row__source {
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--steel);
    text-decoration: none;
    padding: 0.4em 0.9em;
    margin-left: 0.5rem;
    border: 1px solid var(--line-on-ink);
    border-radius: 999px;
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .archive-row__source:hover {
    color: var(--apricot);
    border-color: var(--apricot);
  }

  @media (max-width: 860px) {
    .archive-row__link {
      grid-template-columns: 2.2rem 1fr auto;
    }

    .archive-row__summary,
    .archive-row__arrow {
      display: none;
    }
  }
</style>
