---
import 'katex/dist/katex.min.css';
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatter = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<Layout title={post.data.title} description={post.data.excerpt}>
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress__fill" data-progress-fill></div>
  </div>

  <Header />
  <main>
    <article class="section post" data-post-article>
      <div class="wrap post__wrap">
        <a class="post__back" href="/blog" data-cursor-hover>← All posts</a>

        <time class="post__date" datetime={post.data.date.toISOString()}>
          {formatter.format(post.data.date)}
        </time>
        <h1 class="post__title" data-text-reveal>{post.data.title}</h1>

        <ul class="post__tags">
          {post.data.tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>

        <div class="post__content">
          <Content />
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<script>
  import { initReadingProgress } from '@/scripts/readingProgress';
  import { initTextReveal } from '@/scripts/textReveal';

  initTextReveal('[data-text-reveal]');
  initReadingProgress('[data-post-article]', '[data-progress-fill]');
</script>

<style>
  .reading-progress {
    position: sticky;
    top: 0;
    z-index: 51;
    height: 3px;
    width: 100%;
    background: transparent;
  }

  .reading-progress__fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--teal), var(--coral));
    transition: width 0.1s linear;
  }

  .post__wrap {
    max-width: 42rem;
  }

  .post__back {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--teal);
    text-decoration: none;
  }

  .post__date {
    display: block;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-faint);
  }

  .post__title {
    margin-top: 0.75rem;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--fg-primary);
  }

  .post__title :global(.tr-word) {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.4em);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--tr-i) * 0.045s);
  }

  .post__title:global(.tr-done) :global(.tr-word) {
    opacity: 1;
    transform: translateY(0);
  }

  .post__tags {
    margin-top: 1.25rem;
    display: flex;
    gap: 0.5rem;
  }

.post__content :global(.katex-display) {
  overflow-x: auto;
  overflow-y: hidden;
  padding-block: 0.25rem;
}

  .post__content {
    margin-top: 2.5rem;
    color: var(--fg-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .post__content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post__content :global(h2) {
    color: var(--fg-primary);
    font-size: 1.3rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post__content :global(a) {
    color: var(--teal);
  }

  .post__content :global(code) {
    font-family: var(--font-mono);
    background: var(--paper-deep);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
