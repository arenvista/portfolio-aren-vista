---

<div class="content">
    <header class="header">
        <h1>Aren Vista</h1>
        <div class="contact-info">
            <a href={CONTACT.websiteUrl} target="_blank" rel="noreferrer">{CONTACT.websiteLabel}</a>
            {' | '}
            <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
            {' | '}
            <a href={CONTACT.phoneUrl}>{CONTACT.phoneLabel}</a>
        </div>
    </header>

    <section class="section">
        <h2>Education</h2>
        <div class="section-content">
            {EDUCATION.map((edu) => (
                <div class="flex-row">
                    <div class="flex-col-main">{edu.degree}</div>
                    <div class="flex-col-sub right-align">{edu.school}</div>
                    <div class="flex-col-date right-align">{edu.year}</div>
                </div>
            ))}
        </div>
    </section>

    <section class="section">
        <h2>Experience</h2>
        <div class="section-content">
            {EXPERIENCE.map((job) => (
                <article class="item-block">
                    <div class="flex-row item-header">
                        <span class="bold">
                            {job.title} <span class="org-text">| {job.organization}</span>
                        </span>
                        <span>{job.date}</span>
                    </div>
                    <ul>
                        {job.bullets.map((bullet) => (
                            <li>{bullet}</li>
                        ))}
                    </ul>
                </article>
            ))}
        </div>
    </section>

    <section class="section">
        <h2>Conferences, Publications & Acknowledgements</h2>
        <div class="section-content">
            {PUBLICATIONS.map((entry) => (
                <div class="citation">
                    <strong>{entry.type}:</strong> {entry.authors} ({entry.year}). {entry.title} <em>{entry.source}</em>, {entry.detail}.
                </div>
            ))}
            <div class="citation">
                <strong>Conferences:</strong> {CONFERENCES.join(', ')}.
            </div>
        </div>
    </section>

    <section class="section">
        <h2>Teaching</h2>
        <div class="section-content">
            {TEACHING_ROLES.map((role) => (
                <div class="flex-row item-header" style="margin-top: 4px;">
                    <span class="bold">
                        {role.title} <span class="org-text">| {role.organization}</span>
                    </span>
                    <span>{role.date}</span>
                </div>
            ))}

            <div style="margin-top: 4px;">
                <div class="flex-row item-header">
                    <span class="bold">
                        {TUTORING.title} <span class="org-text">| {TUTORING.organization}</span>
                    </span>
                    <span>{TUTORING.date}</span>
                </div>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px 16px; margin-top: 6px; font-size: 0.9em;">
                    {TUTORING_COURSES.map((course) => (
                        <div>
                            {course.code} {course.name}
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <h2>Skills</h2>
        <div class="section-content">
            <div class="skills-compact">
                {Object.entries(SKILLS).map(([category, skills]) => (
                    <div>
                        <strong>{category}:</strong> {skills}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="section">
        <h2>Projects</h2>
        <div class="section-content">
            <div class="projects-list">
                {PROJECTS.map((proj) => (
                    <div class="project-row">
                        <div class="project-name">
                            <a href={proj.link} target="_blank" rel="noreferrer">{proj.name}</a>
                        </div>
                        <div class="project-desc">{proj.desc}</div>
                    </div>
                ))}
            </div>
        </div>
    </section>
</div>
