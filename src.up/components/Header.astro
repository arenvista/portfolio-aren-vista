---
import { site, nav } from '@/data/site';
import navIcon1 from '../assets/img/nav-icon1.svg';
import navIcon2 from '../assets/img/github-mark-white.svg';
import navIcon3 from '../assets/img/gitlab-logo-700.png';
---

<header class="site-header">
  <div class="site-header__container wrap">
    <a href="#top" class="site-header__mark" aria-label={`${site.name} — home`} data-cursor-hover>
      <span class="site-header__dot" aria-hidden="true"></span>
      <span class="site-header__name">{site.name}</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary" data-nav-underline>
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} data-cursor-hover>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="social-icon">
      <a href="https://www.linkedin.com/in/aren-vista-079199203/" data-cursor-hover><img src={navIcon1.src} alt="LinkedIn" /></a>
      <a href="https://github.com/arenvista" data-cursor-hover><img src={navIcon2.src} alt="GitHub" /></a>
      <a href="https://gitlab.com/arenvista" data-cursor-hover><img src={navIcon3.src} alt="GitLab" /></a>
    </div>
  </div>
</header>

<script>
  import { initNavUnderline } from '@/scripts/navUnderline';
  initNavUnderline('[data-nav-underline] ul');
</script>

<style>
.social-icon {
  display: flex;
  align-items: center;
  margin-left: 14px;
}
.social-icon a {
  position: relative;
  width: 42px;
  height: 42px;
  background: rgba(255, 255, 255, 0.1);
  display: inline-flex;
  border-radius: 50%;
  margin-right: 6px;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: 1px solid var(--ctp-surface1);
  overflow: hidden;
}
.social-icon a::before {
  content: "";
  width: 42px;
  height: 42px;
  position: absolute;
  background-color: var(--ctp-text);
  border-radius: 50%;
  transform: scale(0);
  transition: 0.3s ease-in-out;
}
.social-icon a:hover::before {
  transform: scale(1);
}
.social-icon a img {
  width: 40%;
  z-index: 1;
  transition: 0.3s ease-in-out;
}
.social-icon a:hover img {
  filter: brightness(0) saturate(100%);
}
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(10px);
  background: color-mix(in srgb, var(--bg-page) 78%, transparent);
  border-bottom: 1px solid var(--border-subtle);
}

.site-header__container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  height: 4.25rem;
}

.site-header__mark {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  font-family: var(--font-display);
  font-weight: 600;
  color: var(--fg-primary);
  letter-spacing: -0.01em;
}

.site-header__dot {
  width: 0.65rem;
  height: 0.65rem;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-mauve), var(--accent-blue));
  flex-shrink: 0;
}

.site-header__nav ul {
  position: relative;
  display: flex;
  align-items: center;
  gap: clamp(1.25rem, 3vw, 2.25rem);
}

.site-header__nav a {
  position: relative;
  z-index: 1;
  text-decoration: none;
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--fg-muted);
  transition: color 0.2s ease;
}

.site-header__nav a:hover {
  color: var(--accent-teal);
}

:global(.nav-underline) {
  position: absolute;
  bottom: -0.4rem;
  left: 0;
  height: 2px;
  width: 0;
  opacity: 0;
  background: var(--accent-teal);
  border-radius: 999px;
  pointer-events: none;
}

.site-header__cta {
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .site-header__nav {
    display: none;
  }
}
</style>
