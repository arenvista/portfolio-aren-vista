---
import { site, skills } from '@/data/site';

const categoryLabels: Record<string, string> = {
  language: 'Languages',
  tool: 'Libraries & Tools',
  concept: 'Concepts',
};

const grouped = skills.reduce<Record<string, typeof skills>>((acc, skill) => {
  (acc[skill.category] ??= []).push(skill);
  return acc;
}, {});
---

<section class="about section" id="about">
  <div class="wrap about__grid">
    <div class="about__intro" data-reveal>
      <div class="about__intro-tilt" data-tilt data-cursor-hover>
        <span class="eyebrow">01 — About</span>
        <h2 class="section-title section-title--with-eyebrow">A little about my work</h2>
        <a href="/resume" class="project-card__link">View Full Resume</a>
      </div>
    </div>

    <div class="about__body">
      <div data-reveal>
        {site.bio.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <div class="about__skills-block" data-reveal style="--reveal-delay: 0.08s;">
        {Object.entries(grouped).map(([category, items]) => (
          <div class="about__skills-group">
            <span class="about__skills-label">{categoryLabels[category] ?? category}</span>
            <ul class="about__skill-bars" aria-label={categoryLabels[category] ?? category}>
              {items.map((skill) => (
                <li class="skill-bar">
                  <div class="skill-bar__head">
                    <span class="skill-bar__label">{skill.label}</span>
                  </div>
                  <div class="skill-bar__track">
                    <div
                      class="skill-bar__fill"
                      data-skill-fill
                      data-skill-level={skill.level ?? 60}
                    ></div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { initScrollReveal } from '@/scripts/reveal';
  import { initSkillBars } from '@/scripts/skillbars';
  import { initTilt } from '@/scripts/tilt';

  initScrollReveal();
  initSkillBars('[data-skill-fill]');
  initTilt('.about__intro-tilt', 4);
</script>

<style>
  .about {
    background: var(--bg-surface);
    border-block: 1px solid var(--border-subtle);
  }

  .about__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
    gap: clamp(2rem, 6vw, 5rem);
  }

  .about__intro {
    position: sticky;
    top: 6rem;
    align-self: start;
  }

  .about__intro-tilt {
    will-change: transform;
  }

  .about__body p {
    color: var(--fg-muted);
    font-size: 1.05rem;
    max-width: 62ch;
  }

  .about__body p + p {
    margin-top: 1.25rem;
  }

  .about__skills-block {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .about__skills-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-teal);
    margin-bottom: 0.85rem;
  }

  .about__skill-bars {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .skill-bar__head {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }

  .skill-bar__label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .skill-bar__track {
    position: relative;
    height: 6px;
    border-radius: 999px;
    background: var(--border-subtle);
    overflow: hidden;
  }

  .skill-bar__fill {
    position: absolute;
    inset: 0;
    width: 0%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent-mauve), var(--accent-blue));
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-bar__fill {
      transition: none;
    }
  }

  @media (max-width: 800px) {
    .about__grid {
      grid-template-columns: 1fr;
    }

    .about__intro {
      position: static;
    }
  }

  .project-card__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--accent-blue);
    transition: color 0.2s ease;
  }
</style>
