---
import { projects } from '@/data/projects';
import ProjectCard from '@/components/ProjectCard.astro';

// Build the distinct set of tags across all projects, for the filter bar.
const allTags = Array.from(new Set(projects.flatMap((p) => p.tags))).sort();
---

<section class="projects section" id="projects">
  <div class="wrap">
    <div class="section-head">
      <div>
        <span class="eyebrow">02 — Projects</span>
        <h2 class="section-title section-title--with-eyebrow">Selected work</h2>
      </div>
      <p class="section-note">A handful of things I've built and shipped.</p>
    </div>

    <div class="projects__filters" data-project-filters role="tablist" aria-label="Filter projects by technology">
      <button type="button" class="filter-btn filter-btn--active" data-filter="all" data-cursor-hover>All</button>
      {allTags.map((tag) => (
        <button type="button" class="filter-btn" data-filter={tag.toLowerCase()} data-cursor-hover>{tag}</button>
      ))}
    </div>

    <div class="projects__grid" data-project-grid>
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>

<script>
  import { initTilt } from '@/scripts/tilt';
  import { initFilterFlip } from '@/scripts/filterFlip';

  initTilt('.projects [data-tilt]', 6);
  initFilterFlip('[data-project-grid]', '[data-project-filters]');
</script>

<style>
  .projects__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4em 0.9em;
    border-radius: 999px;
    border: 1px solid var(--border-subtle);
    color: var(--fg-muted);
    background: transparent;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .filter-btn:hover {
    border-color: var(--accent-teal);
    color: var(--accent-teal);
  }

  .filter-btn--active {
    border-color: var(--accent-primary);
    color: var(--ctp-crust);
    background: var(--accent-primary);
  }

  .filter-btn--active:hover {
    color: var(--ctp-crust);
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: 1.5rem;
  }
</style>
