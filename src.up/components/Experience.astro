---
import { experience } from '@/data/site';
---

<div class="about__experience" data-reveal>
  <ol class="about__timeline" data-reveal style="--reveal-delay: 0.16s;">
    {experience.map((item) => (
      <li class="about__timeline-item">
        <svg class="about__timeline-connector" viewBox="0 0 2 60" preserveAspectRatio="none" aria-hidden="true">
          <line data-drawline x1="1" y1="0" x2="1" y2="60" />
        </svg>

        <div class="about__timeline-info">
          <span class="about__timeline-title">{item.title}</span>
          <div class="about__timeline-subhead">
            <span class="about__timeline-org">{item.organization}</span>
            <span class="about__timeline-separator">•</span>
            <span class="about__timeline-date">{item.date}</span>
          </div>
        </div>

        <ul class="about__timeline-bullets">
          {item.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      </li>
    ))}
  </ol>
</div>

<script>
  import { initScrollReveal } from '@/scripts/reveal';
  import { initDrawLines } from '@/scripts/drawline';

  initScrollReveal();
  initDrawLines('[data-drawline]');
</script>

<style>
  .about__experience {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: clamp(3rem, 8vw, 6rem);
  }

  .about__timeline {
    margin-top: 3rem;
    width: 100%;
    max-width: 1100px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 2.5rem;
  }

  .about__timeline-item {
    position: relative;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: start;
  }

  .about__timeline-connector {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    overflow: visible;
  }

  .about__timeline-connector line {
    stroke: var(--accent-teal);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .about__timeline-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.35rem;
  }

  .about__timeline-title {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--fg-primary);
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .about__timeline-subhead {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .about__timeline-org {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-mauve);
  }

  .about__timeline-separator {
    color: var(--border-subtle);
    font-size: 0.8rem;
    user-select: none;
  }

  .about__timeline-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-faint);
    white-space: nowrap;
  }

  .about__timeline-bullets {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    width: 100%;
    text-align: left;
  }

  .about__timeline-bullets li {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--fg-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .about__timeline-bullets li::before {
    content: '';
    width: 0.4rem;
    height: 1px;
    background: var(--accent-teal);
    flex-shrink: 0;
    margin-top: 0.75rem;
  }

  @media (max-width: 900px) {
    .about__timeline {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
