---
import type { Project } from '@/data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const tagAttr = project.tags.map((t) => t.toLowerCase()).join(' ');
---

<article class="project-card" data-reveal data-tags={tagAttr}>
  <div class="project-card__tilt" data-tilt data-spotlight data-cursor-hover>
    <div class="project-card__spotlight" aria-hidden="true"></div>

    <div class="project-card__top">
      <span class="project-card__year">{project.year}</span>
      {project.featured && <span class="tag project-card__featured">Featured</span>}
    </div>

    <h3 class="project-card__title">{project.title}</h3>
    <p class="project-card__summary">{project.summary}</p>

    <ul class="project-card__tags" aria-label="Technologies used">
      {project.tags.map((tag) => (
        <li>{tag}</li>
      ))}
    </ul>

    <div class="project-card__links">
      <a href={project.href} class="project-card__link">View case study →</a>
      {project.repo && (
        <a href={project.repo} class="project-card__link project-card__link--muted" target="_blank" rel="noopener noreferrer">
          Source
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    position: relative;
    height: 100%;
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card--hidden {
    display: none;
  }

  .project-card__tilt {
    position: relative;
    background: var(--bg-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    will-change: transform;
    transition: border-color 0.2s ease;
  }

  .project-card__tilt:hover {
    border-color: var(--accent-mauve);
  }

  .project-card__spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(
      280px circle at var(--spot-x, 50%) var(--spot-y, 50%),
      color-mix(in srgb, var(--accent-mauve) 16%, transparent),
      transparent 70%
    );
  }

  .project-card__tilt:hover .project-card__spotlight {
    opacity: 1;
  }

  .project-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    position: relative;
  }

  .project-card__year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-faint);
  }

  .project-card__featured {
    color: var(--accent-primary);
    border-color: color-mix(in srgb, var(--accent-primary) 40%, transparent);
  }

  .project-card__title {
    position: relative;
    font-size: 1.3rem;
    color: var(--fg-primary);
    margin-bottom: 0.6rem;
  }

  .project-card__summary {
    position: relative;
    color: var(--fg-muted);
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .project-card__tags {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-teal);
  }

  .project-card__tags li::before {
    content: '#';
    opacity: 0.6;
    margin-right: 0.1em;
  }

  .project-card__links {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-subtle);
  }

  .project-card__link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--accent-blue);
    transition: color 0.2s ease;
  }

  .project-card__link--muted {
    color: var(--fg-faint);
  }

  .project-card__link:hover {
    color: var(--accent-primary);
  }
</style>
